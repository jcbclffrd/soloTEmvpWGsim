# soloTEmvpWGsim - Git ignore patterns

# ==============================================================================
# Large Reference Files (downloaded/built by setup scripts)
# ==============================================================================
references/genome/*.fa
references/genome/*.fa.fai
references/genome/*.fa.gz
references/annotations/*.bed
references/annotations/*.gff3
references/annotations/*.gtf
references/STARsolo_index/*

# Keep README files
!references/README.md
!references/**/README.md

# ==============================================================================
# Software Installations
# ==============================================================================
software/SoloTE/
software/*

# ==============================================================================
# Generated Data (created by pipeline)
# ==============================================================================
synthetic_data/transcriptome/*.fa
synthetic_data/transcriptome/*.fai
synthetic_data/transcriptome/*.original
synthetic_data/fastqs/*.fastq
synthetic_data/fastqs/*.fastq.gz
synthetic_data/outputs/

# Archive folders (created by scripts/00_archive_and_clean.sh)
# These contain timestamped backups of previous runs
**/archive/

# Keep ground truth and small metadata files
!ground_truth/*.tsv
!ground_truth/*.bed
!synthetic_data/transcriptome/*.txt
!synthetic_data/transcriptome/cell_barcodes.txt
!synthetic_data/transcriptome/expression_profile.tsv
!synthetic_data/transcriptome/expression_summary.txt

# ==============================================================================
# Validation Outputs
# ==============================================================================
validation_report/*.pdf
validation_report/*.png
validation_report/*.html

# Keep small text outputs that show results
!validation_report/README.md
!validation_report/*.tsv

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# ==============================================================================
# R
# ==============================================================================
.Rhistory
.RData
.Rproj.user
*.Rproj

# ==============================================================================
# Jupyter
# ==============================================================================
.ipynb_checkpoints/
*.ipynb

# ==============================================================================
# Log files
# ==============================================================================
*.log
*.out
*.err
logs/

# ==============================================================================
# Temporary files
# ==============================================================================
*.tmp
*.temp
*.swp
*~
.DS_Store

# ==============================================================================
# SLURM job files (if running on HPC)
# ==============================================================================
slurm-*.out

# ==============================================================================
# Conda environment
# ==============================================================================
.conda/

# ==============================================================================
# Analysis data directories (large downloads — see analysis/*/MANIFEST.md)
# Scripts and MANIFEST are tracked; data/ and results/ are not.
# ==============================================================================
analysis/liftover/data/
analysis/liftover/results/*.bed
analysis/liftover/results/*.tsv
analysis/liftover/results/*.md
analysis/liftover/results/*.tex
analysis/liftover/results/*.log
# Keep the rendered HTML reports
!analysis/liftover/results/REPORT.html
!analysis/liftover/results/REPORT2.html

analysis/te_polymorphism/data/
analysis/te_polymorphism/results/
